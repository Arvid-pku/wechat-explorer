{
  "name": "wechat-explorer",
  "version": "0.1.2",
  "private": true,
  "description": "Local-first explorer for your WeChat chat history",
  "author": "WeChat Explorer contributors",
  "main": "electron/dist/main.js",
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "setup:dev": "bash scripts/setup.sh --dev",
    "dev": "next dev --port 3719",
    "build": "next build",
    "start": "next start --port 3719",
    "lint": "eslint",
    "index:quick": "tsx scripts/index.ts",
    "index:deep": "tsx scripts/index.ts --deep",
    "index:full": "tsx scripts/index.ts --full",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:tsc": "tsc -p electron",
    "app:dev": "npm run electron:tsc && NEXT_DEV_SERVER_URL=http://localhost:3719 electron electron/dist/main.js",
    "build:app": "bash scripts/build-app.sh",
    "build:app:dmg": "bash scripts/build-app.sh --dmg"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-table": "^8.21.3",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "d3": "^7.9.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/d3": "^7.4.3",
    "@types/node": "^20.19.41",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.6",
    "electron": "^38.8.6",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.0",
    "typescript": "^5",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=21"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "better-sqlite3",
    "sharp",
    "unrs-resolver"
  ]
}
